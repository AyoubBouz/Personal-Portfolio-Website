# EmailJS credentials for the contact form (optional).
# Sign up at https://www.emailjs.com, create a service + template,
# then drop the keys here AND in Vercel -> Project Settings -> Environment Variables.
#
# Without these, the form still renders but submission will fail silently.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
